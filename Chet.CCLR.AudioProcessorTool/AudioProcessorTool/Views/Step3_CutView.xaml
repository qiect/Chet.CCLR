<UserControl x:Class="AudioProcessorTool.Views.Step3_CutView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:AudioProcessorTool.Views"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="900"
             Loaded="UserControl_Loaded">
    <UserControl.Resources>
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1D4ED8"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#1D4ED8"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- 文件设置区域 -->
        <Border Background="White" CornerRadius="8" Padding="20" BorderBrush="#E2E8F0" BorderThickness="1">
            <StackPanel Orientation="Horizontal" Margin="0,5">
                <Button Content="📁 选择原始音频" Width="140" Click="BtnSelectAudio_Click" Margin="0,0,10,0"/>
                <TextBlock x:Name="TxtAudioPath" VerticalAlignment="Center" Width="500" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" Margin="10,0,0,0" Foreground="#64748B"/>
            </StackPanel>
        </Border>
        
        <!-- 标签文件区域 -->
        <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="20" BorderBrush="#E2E8F0" BorderThickness="1" Margin="0,20,0,0">
            <StackPanel Orientation="Horizontal" Margin="0,5">
                <Button Content="📋 选择 labels.txt" Width="140" Click="BtnSelectLabels_Click" Margin="0,0,10,0"/>
                <TextBlock x:Name="TxtLabelsPath" VerticalAlignment="Center" Width="500" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" Margin="10,0,0,0" Foreground="#64748B"/>
            </StackPanel>
        </Border>
        
        <!-- 切割设置区域 -->
        <Border Grid.Row="2" Background="White" CornerRadius="8" Padding="20" BorderBrush="#E2E8F0" BorderThickness="1" Margin="0,20,0,0">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBlock Text="FFmpeg 状态:" Margin="0,0,10,0" FontWeight="SemiBold" Foreground="#1E293B"/>
                    <TextBlock x:Name="TxtFFmpegStatus" Margin="0,0,0,0" Foreground="#64748B"/>
                </StackPanel>
                <TextBlock Text="说明:" FontWeight="SemiBold" Margin="0,10,0,10" Foreground="#1E293B"/>
                <TextBlock Text="• 如果 FFmpeg 可用，将使用 FFmpeg 进行真实音频切割" TextWrapping="Wrap" Margin="0,0,0,8" Foreground="#64748B" LineHeight="18"/>
                <TextBlock Text="• 如果 FFmpeg 不可用，将创建模拟音频文件用于演示" TextWrapping="Wrap" Margin="0,0,0,8" Foreground="#64748B" LineHeight="18"/>
            </StackPanel>
        </Border>
        
        <!-- 操作指南 -->
        <Border Grid.Row="3" Background="#F8FAFC" CornerRadius="8" Padding="20" BorderBrush="#E2E8F0" BorderThickness="1" Margin="0,20,0,0">
            <StackPanel>
                <TextBlock Text="📋 操作指南" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,15" Foreground="#1E293B"/>
                <TextBlock Text="1. 选择原始音频文件 (.mp3, .wav, .m4a 等)" TextWrapping="Wrap" Margin="0,0,0,10" Foreground="#64748B" LineHeight="18"/>
                <TextBlock Text="2. 选择 labels.txt 标签文件" TextWrapping="Wrap" Margin="0,0,0,10" Foreground="#64748B" LineHeight="18"/>
                <TextBlock Text="3. 点击开始切割按钮" TextWrapping="Wrap" Margin="0,0,0,10" Foreground="#64748B" LineHeight="18"/>
                <TextBlock Text="4. 查看输出结果" TextWrapping="Wrap" Margin="0,0,0,10" Foreground="#64748B" LineHeight="18"/>
            </StackPanel>
        </Border>
        
        <!-- 开始切割按钮 -->
        <Button x:Name="BtnCut" Content="✂️ 开始切割" Width="180" Height="50" FontSize="16" FontWeight="SemiBold" Click="BtnCut_Click" Grid.Row="4" Margin="0,20,0,0" HorizontalAlignment="Center" Background="#2563EB" Foreground="White" Style="{StaticResource PrimaryButtonStyle}"/>
        
        <!-- 输出内容 -->
        <Border Grid.Row="5" Background="#F8FAFC" CornerRadius="8" Padding="20" BorderBrush="#E2E8F0" BorderThickness="1" Margin="0,20,0,0">
            <StackPanel>
                <TextBlock Text="📁 输出内容" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,15" Foreground="#1E293B"/>
                <TextBlock Text="切割完成后会生成以下内容:" Margin="0,0,0,10" Foreground="#64748B"/>
                <TextBlock Text="• audio/ 文件夹 - 包含切割后的音频片段" TextWrapping="Wrap" Margin="0,0,0,8" Foreground="#64748B" LineHeight="18"/>
                <TextBlock Text="• insert_script.sql - 数据库插入脚本" TextWrapping="Wrap" Margin="0,0,0,8" Foreground="#64748B" LineHeight="18"/>
                <TextBlock Text="• README.md - 使用说明文档" TextWrapping="Wrap" Margin="0,0,0,8" Foreground="#64748B" LineHeight="18"/>
            </StackPanel>
        </Border>
        
        <!-- 状态栏 -->
        <Border Grid.Row="6" Background="White" CornerRadius="8" Padding="15" BorderBrush="#E2E8F0" BorderThickness="1" Margin="0,20,0,0">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="状态:" FontWeight="SemiBold" Foreground="#1E293B" Margin="0,0,10,0"/>
                <TextBlock x:Name="TxtStatus" Text="就绪" Foreground="#64748B"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>