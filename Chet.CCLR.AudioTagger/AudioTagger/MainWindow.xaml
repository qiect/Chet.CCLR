<Window x:Class="AudioTagger.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AudioTagger"
        mc:Ignorable="d"
        Title="音频标签工具 - 道德经" Height="700" Width="1200" WindowStartupLocation="CenterScreen" KeyDown="Window_KeyDown">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 文件选择区域 -->
        <GroupBox Header="文件设置" Grid.Row="0" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                <Button x:Name="BtnSelectAudio" Content="选择音频文件" Width="120" Height="30" Click="BtnSelectAudio_Click" Margin="0,0,5,0"/>
                <Button x:Name="BtnSelectSentences" Content="选择句子文件" Width="120" Height="30" Click="BtnSelectSentences_Click" Margin="0,0,5,0"/>
                <Button x:Name="BtnLoad" Content="加载" Width="80" Height="30" Click="BtnLoad_Click" Margin="0,0,5,0"/>
                <TextBlock x:Name="TxtAudioPath" VerticalAlignment="Center" Width="300" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"/>
                <TextBlock x:Name="TxtSentencePath" VerticalAlignment="Center" Width="300" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"/>
            </StackPanel>
        </GroupBox>

        <!-- 控制面板 -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <Button x:Name="BtnPlayPause" Content="播放/暂停" Width="100" Height="35" Click="BtnPlayPause_Click" Margin="0,0,5,0"/>
            <Button x:Name="BtnStop" Content="停止" Width="80" Height="35" Click="BtnStop_Click" Margin="0,0,5,0"/>
            <Button x:Name="BtnAddTag" Content="添加标签" Width="100" Height="35" Click="BtnAddTag_Click" Margin="0,0,5,0"/>
            <Button x:Name="BtnEditTag" Content="编辑标签" Width="100" Height="35" Click="BtnEditTag_Click" Margin="0,0,5,0"/>
            <Button x:Name="BtnDeleteTag" Content="删除标签" Width="100" Height="35" Click="BtnDeleteTag_Click" Margin="0,0,5,0"/>
            <Button x:Name="BtnExport" Content="导出标签" Width="100" Height="35" Click="BtnExport_Click" Margin="0,0,5,0"/>
            <Button x:Name="BtnSaveSentences" Content="保存句子" Width="100" Height="35" Click="BtnSaveSentences_Click" Margin="0,0,5,0"/>
            <TextBlock x:Name="TxtCurrentTime" VerticalAlignment="Center" FontSize="14" Width="120" Margin="0,0,5,0"/>
            <TextBlock x:Name="TxtTotalTime" VerticalAlignment="Center" FontSize="14" Width="120"/>
        </StackPanel>

        <!-- 标签列表 -->
        <GroupBox Header="标签列表" Grid.Row="2" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="200"/>
                </Grid.ColumnDefinitions>
                
                <ListView x:Name="LvTags" Grid.Column="0" ItemsSource="{Binding Tags}" SelectionMode="Single" SelectionChanged="LvTags_SelectionChanged">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="序号" Width="60" DisplayMemberBinding="{Binding Index}"/>
                            <GridViewColumn Header="开始时间" Width="100" DisplayMemberBinding="{Binding StartTime, StringFormat=\{0:0.000\}}"/>
                            <GridViewColumn Header="结束时间" Width="100" DisplayMemberBinding="{Binding EndTime, StringFormat=\{0:0.000\}}"/>
                            <GridViewColumn Header="时长" Width="80" DisplayMemberBinding="{Binding Duration, StringFormat=\{0:0.000\}}"/>
                            <GridViewColumn Header="内容" Width="Auto" DisplayMemberBinding="{Binding Content}"/>
                        </GridView>
                    </ListView.View>
                </ListView>

                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                    <TextBlock Text="当前选中句子：" FontWeight="Bold"/>
                    <TextBox x:Name="TxtSelectedSentence" Height="80" TextWrapping="Wrap" AcceptsReturn="True" IsReadOnly="True" Margin="0,5,0,10"/>
                    
                    <TextBlock Text="编辑句子内容：" FontWeight="Bold"/>
                    <TextBox x:Name="TxtEditSentence" Height="80" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,10"/>
                    
                    <Button x:Name="BtnUpdateSentence" Content="更新句子内容" Width="120" Height="30" Click="BtnUpdateSentence_Click" Margin="0,0,0,10"/>
                    
                    <TextBlock Text="提示：" FontWeight="Bold"/>
                    <TextBlock Text="1. 加载音频和句子文件" TextWrapping="Wrap" Margin="0,5,0,0"/>
                    <TextBlock Text="2. 播放音频，按空格键或点击'添加标签'添加标签" TextWrapping="Wrap" Margin="0,5,0,0"/>
                    <TextBlock Text="3. 可以编辑句子内容" TextWrapping="Wrap" Margin="0,5,0,0"/>
                    <TextBlock Text="4. 导出标签文件供AudioProcessor使用" TextWrapping="Wrap" Margin="0,5,0,0"/>
                </StackPanel>
            </Grid>
        </GroupBox>

        <!-- 状态栏 -->
        <StatusBar Grid.Row="3" Background="LightGray">
            <StatusBarItem>
                <TextBlock x:Name="TxtStatus">就绪</TextBlock>
            </StatusBarItem>
        </StatusBar>

        <!-- 进度条 -->
        <Grid Grid.Row="4" Margin="0,10,0,0">
            <Slider x:Name="SliTimeline" Minimum="0" Maximum="100" ValueChanged="SliTimeline_ValueChanged" PreviewMouseUp="SliTimeline_PreviewMouseUp"/>
        </Grid>
    </Grid>
</Window>