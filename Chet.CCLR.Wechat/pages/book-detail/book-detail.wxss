/* 全局背景色延续宣纸感 */
.container {
  min-height: 100vh;
  background-color: #f9f7f2;
}

/* 顶部书目头图 */
.book-header {
  padding: 60rpx 40rpx;
  background: #2c3e50; /* 黛蓝 */
  display: flex;
  align-items: center;
  position: relative;
  overflow: hidden;
}

.book-cover {
  width: 180rpx;
  height: 240rpx;
  border-radius: 8rpx;
  box-shadow: 0 10rpx 30rpx rgba(0,0,0,0.3);
  z-index: 2;
  border: 2rpx solid rgba(255,255,255,0.1);
}

.book-meta {
  margin-left: 40rpx;
  z-index: 2;
}

.title {
  display: block;
  font-size: 44rpx;
  font-weight: bold;
  color: #e0d1b1; /* 象牙白 */
  margin-bottom: 20rpx;
}

.category-tag {
  font-size: 24rpx;
  color: #a64036; /* 朱砂红 */
  background: rgba(166, 64, 54, 0.15);
  padding: 4rpx 16rpx;
  border-radius: 4rpx;
  border: 1rpx solid #a64036;
}

.header-bg {
  position: absolute;
  right: -50rpx;
  bottom: -50rpx;
  width: 300rpx;
  height: 300rpx;
  background: rgba(255,255,255,0.03);
  border-radius: 50%;
}

/* 内容区域 */
.content-scroll {
  height: calc(100vh - 400rpx);
}

.info-section, .chapters-section {
  background: #fff;
  margin: 24rpx;
  padding: 40rpx 30rpx;
  border-radius: 12rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.02);
}

.section-title-box {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
  position: relative;
}

.section-title::after {
  content: "";
  position: absolute;
  bottom: -8rpx;
  left: 0;
  width: 40rpx;
  height: 4rpx;
  background: #a64036;
}

.chapter-total {
  font-size: 24rpx;
  color: #999;
}

.description-content .text {
  font-size: 28rpx;
  color: #555;
  line-height: 1.8;
  text-align: justify;
}

/* 章节列表美化 */
.chapter-item {
  display: flex;
  align-items: center;
  padding: 30rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.chapter-item:last-child {
  border-bottom: none;
}

.item-hover {
  background-color: #fcfaf7;
}

.chapter-num {
  font-size: 32rpx;
  font-family: "Georgia", serif;
  color: #ccc;
  width: 60rpx;
}

.chapter-info {
  flex: 1;
}

.chapter-title {
  display: block;
  font-size: 30rpx;
  color: #333;
  margin-bottom: 8rpx;
}

.sentence-count {
  font-size: 24rpx;
  color: #a64036; /* 朱砂红，强调学习感 */
  opacity: 0.8;
}

.arrow-icon {
  width: 24rpx;
  height: 24rpx;
  opacity: 0.3;
}

/* 底部按钮 */
.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 30rpx 50rpx 60rpx;
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(10px);
  z-index: 10;
}

.primary-btn {
  background: #a64036 !important; /* 统一使用朱砂红 */
  color: #fff !important;
  border-radius: 50rpx;
  height: 90rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  box-shadow: 0 10rpx 30rpx rgba(166, 64, 54, 0.3);
}

.btn-text {
  font-size: 32rpx;
  font-weight: 500;
  letter-spacing: 2rpx;
}

.safe-area-bottom {
  height: 180rpx;
}