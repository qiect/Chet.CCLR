<view class="container">
  <view class="header">
    <text class="title">全部书目</text>
    <view class="search-box">
      <input 
        class="search-input" 
        type="text" 
        placeholder="搜索书名或作者" 
        placeholder-class="placeholder"
        value="{{keyword}}"
        bindinput="onSearchInput"
        bindconfirm="onSearchConfirm"
      />
      <button class="search-btn" type="primary" bindtap="onSearchConfirm">搜索</button>
    </view>
  </view>

  <scroll-view class="content" scroll-y>
    <view class="book-list">
      <block wx:for="{{books}}" wx:key="id">
        <view class="book-item" bindtap="onBookTap" data-book="{{item}}">
          <image class="cover" src="{{item.cover || '/assets/images/book-default.png'}}" mode="aspectFill"></image>
          <view class="info">
            <text class="title">{{item.title}}</text>
            <text class="category">{{item.category}}</text>
          </view>
        </view>
      </block>
      <view wx:if="{{books.length === 0}}" class="empty-tip">
        <text>暂无书目数据</text>
      </view>
    </view>
  </scroll-view>
</view>
