.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #f8f9fa;
}

.header {
  padding: 40rpx;
  text-align: center;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
}

.search-box {
  margin-top: 30rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}

.search-input {
  flex: 1;
  height: 64rpx;
  line-height: 64rpx;
  padding: 0 30rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 32rpx;
  font-size: 28rpx;
  color: #333;
  margin-right: 20rpx;
}

.placeholder {
  color: #999;
}

.search-btn {
  width: 160rpx;
  height: 64rpx;
  line-height: 64rpx;
  font-size: 28rpx;
  border-radius: 32rpx;
  padding: 0;
}

.content {
  flex: 1;
  padding: 20rpx;
}

.book-list {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.book-item {
  width: 48%;
  margin-bottom: 30rpx;
  background: white;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.cover {
  width: 100%;
  height: 300rpx;
  display: block;
}

.info {
  padding: 20rpx;
}

.title {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 10rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.category {
  font-size: 24rpx;
  color: #999;
}

.empty-tip {
  text-align: center;
  padding: 60rpx 20rpx;
  color: #999;
  font-size: 28rpx;
}
