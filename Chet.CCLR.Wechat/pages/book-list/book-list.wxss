page {
  background-color: #f4f1ea; /* 宣纸色 */
  height: 100%;
}

.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
}

/* 顶部 Header */
.page-header {
  background-color: #ffffff;
  padding: 60rpx 40rpx 30rpx;
  border-bottom: 1rpx solid #e0dcd3;
  flex-shrink: 0;
}

.header-main {
  text-align: center;
  margin-bottom: 30rpx;
}

.page-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #5c4e44; /* 黛色 */
  letter-spacing: 4rpx;
  display: block;
}

.page-subtitle {
  font-size: 22rpx;
  color: #a64036; /* 朱砂红 */
  margin-top: 8rpx;
  display: block;
  opacity: 0.8;
}

/* 搜索框优化 */
.search-container {
  padding: 0 10rpx;
}

.search-bar {
  display: flex;
  align-items: center;
  background: #f8f6f0;
  border: 1rpx solid #e0dcd3;
  height: 72rpx;
  border-radius: 36rpx;
  padding: 0 30rpx;
}

.search-input {
  flex: 1;
  font-size: 26rpx;
  color: #333;
  padding: 0 15rpx;
}

.placeholder-style {
  color: #bbb3a9;
}

.search-action {
  font-size: 26rpx;
  color: #8d7a66;
  font-weight: 500;
  padding-left: 20rpx;
  border-left: 1rpx solid #e0dcd3;
}

/* 列表网格 */
.scroll-content {
  flex: 1;
  overflow: hidden;
}

.book-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 30rpx 25rpx;
  justify-content: space-between;
}

.book-card {
  width: 334rpx; /* 适配双栏布局 */
  background: #ffffff;
  margin-bottom: 40rpx;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 20rpx rgba(92, 78, 68, 0.1);
  transition: transform 0.2s;
}

.book-card:active {
  transform: scale(0.98);
}

/* 书籍封面装饰 */
.cover-wrapper {
  position: relative;
  width: 100%;
  height: 440rpx;
}

.book-cover {
  width: 100%;
  height: 100%;
  background-color: #eee;
}

.book-spine {
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 12rpx;
  background: linear-gradient(to right, rgba(0,0,0,0.2), rgba(0,0,0,0));
}

/* 书籍文字信息 */
.book-info {
  padding: 20rpx;
  text-align: center;
}

.book-title {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-bottom: 12rpx;
}

.book-meta {
  display: flex;
  justify-content: center;
}

.category-tag {
  font-size: 20rpx;
  color: #8d7a66;
  border: 1rpx solid #dcd3c1;
  padding: 2rpx 12rpx;
  border-radius: 4rpx;
  background: #fdfaf5;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
}

.empty-img {
  width: 200rpx;
  height: 200rpx;
  opacity: 0.6;
}

.empty-text {
  margin-top: 30rpx;
  font-size: 26rpx;
  color: #8d7a66;
}

.footer-gap {
  height: 60rpx;
}