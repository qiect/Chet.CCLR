.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #f8f9fa;
}

.header {
  padding: 30rpx;
  background: white;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.book-info {
  text-align: center;
}

.book-title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.chapter-title {
  font-size: 28rpx;
  color: #666;
}

.content {
  flex: 1;
  padding: 30rpx 20rpx;
}

.sentences {
  min-height: 100%;
}

.sentence-item {
  padding: 40rpx 30rpx;
  margin-bottom: 20rpx;
  background: white;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
  transition: all 0.3s ease;
}

.sentence-item.active {
  background: #fff9db;
  transform: scale(1.02);
  box-shadow: 0 6rpx 16rpx rgba(0, 0, 0, 0.1);
}

.pinyin {
  font-size: 24rpx;
  color: #888;
  margin-bottom: 10rpx;
  line-height: 1.4;
}

.content {
  font-size: 32rpx;
  color: #333;
  line-height: 1.6;
  text-align: center;
}

.note {
  font-size: 26rpx;
  color: #666;
  margin-top: 15rpx;
  padding-top: 15rpx;
  border-top: 1rpx solid #eee;
  line-height: 1.4;
}

.controls {
  background: white;
  padding: 30rpx 20rpx;
  border-top: 1rpx solid #eee;
}

.progress-bar {
  margin-bottom: 30rpx;
}

.progress-bg {
  height: 6rpx;
  background: #e0e0e0;
  border-radius: 3rpx;
  margin-bottom: 10rpx;
  position: relative;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #667eea 0%, #764ba2 100%);
  border-radius: 3rpx;
  transition: width 0.1s ease;
}

.progress-thumb {
  position: absolute;
  top: -7rpx;
  transform: translateX(-50%);
  width: 20rpx;
  height: 20rpx;
  background: #fff;
  border: 2rpx solid #667eea;
  border-radius: 50%;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.2);
  pointer-events: none;
}

.time-display {
  position: absolute;
  top: -50rpx;
  left: 50%;
  transform: translateX(-50%);
  background: rgba(0, 0, 0, 0.75);
  color: #fff;
  padding: 10rpx 20rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  white-space: nowrap;
  z-index: 10;
}

.control-buttons {
  display: flex;
  justify-content: center;
  align-items: center;
  margin-bottom: 20rpx;
}

.btn {
  display: flex;
  justify-content: center;
  align-items: center;
  width: 80rpx;
  height: 80rpx;
  margin: 0 30rpx;
  background: #667eea;
  border-radius: 50%;
  color: white;
}

.btn.play {
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.btn image {
  width: 40rpx;
  height: 40rpx;
}

.action-buttons {
  display: flex;
  justify-content: center;
}

.action-buttons .btn {
  width: auto;
  height: 60rpx;
  padding: 0 30rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
}
