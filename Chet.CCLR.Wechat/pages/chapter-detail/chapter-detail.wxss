.container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

.header {
  padding: 40rpx;
  text-align: center;
  background: white;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.book-info {
  text-align: center;
}

.book-title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.chapter-title {
  font-size: 28rpx;
  color: #667eea;
}

.content {
  padding: 20rpx;
}

.sentences {
  min-height: 100%;
}

.sentence-item {
  padding: 40rpx 30rpx;
  margin-bottom: 20rpx;
  background: white;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.pinyin {
  font-size: 24rpx;
  color: #888;
  margin-bottom: 10rpx;
  line-height: 1.4;
}

.content {
  font-size: 32rpx;
  color: #333;
  line-height: 1.6;
  text-align: center;
}

.note {
  font-size: 26rpx;
  color: #666;
  margin-top: 15rpx;
  padding-top: 15rpx;
  border-top: 1rpx solid #eee;
  line-height: 1.4;
}

.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 30rpx;
  background: white;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.btn {
  width: 100%;
  height: 80rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 40rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  color: white;
  font-size: 32rpx;
  font-weight: bold;
}
