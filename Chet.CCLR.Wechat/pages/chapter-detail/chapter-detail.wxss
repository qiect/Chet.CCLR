page {
  height: 100%;
  background-color: #f4f1ea; /* 宣纸色 */
}

.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
}

/* 顶部 */
.page-header {
  flex-shrink: 0;
  padding: 80rpx 40rpx 30rpx;
  background: linear-gradient(to bottom, #f4f1ea, rgba(244,241,234,0.8));
  text-align: center;
  z-index: 10;
}

.book-name {
  font-size: 28rpx;
  color: #8d7a66;
  letter-spacing: 2rpx;
}

.chapter-badge {
  display: inline-block;
  margin-top: 10rpx;
  padding: 4rpx 24rpx;
  background: #a64036;
  border-radius: 40rpx;
}

.chapter-name {
  font-size: 24rpx;
  color: #fff;
}

/* 滚动区 */
.reader-container {
  flex: 1;
  overflow: hidden;
}

.sentence-list {
  padding: 40rpx;
}

.sentence-item {
  padding: 40rpx;
  margin-bottom: 30rpx;
  border-radius: 16rpx;
  transition: all 0.3s ease;
  background: rgba(255,255,255,0.4);
}

.sentence-item.active {
  background: #fff;
  box-shadow: 0 10rpx 30rpx rgba(166, 64, 54, 0.1);
  transform: scale(1.02);
}

.pinyin-box {
  text-align: center;
  height: 34rpx;
  margin-bottom: 10rpx;
}

.pinyin-text {
  font-size: 22rpx;
  color: #a64036;
  opacity: 0.8;
}

.content-text {
  font-size: 38rpx;
  line-height: 1.6;
  color: #333;
  text-align: center;
  font-family: "STSong", "SimSun", serif;
}

.active .content-text {
  color: #a64036;
  font-weight: bold;
}

.note-box {
  margin-top: 30rpx;
  padding-top: 20rpx;
  border-top: 1rpx dashed #eee;
  display: flex;
}

.note-tag {
  width: 32rpx;
  height: 32rpx;
  background: #8d7a66;
  color: #fff;
  font-size: 20rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  border-radius: 4rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
  margin-top: 6rpx;
}

.note-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
}

.bottom-gap { height: 300rpx; }

/* 控制台 */
.footer-controls {
  flex-shrink: 0;
  background: #fff;
  padding: 30rpx 40rpx 60rpx;
  box-shadow: 0 -10rpx 40rpx rgba(0,0,0,0.05);
  border-radius: 40rpx 40rpx 0 0;
}

.progress-wrapper {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
}

.audio-slider { flex: 1; margin: 0 20rpx; }

.time-num { font-size: 20rpx; color: #999; width: 60rpx; }

.btn-group {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.main-play-box {
  display: flex;
  align-items: center;
}

.nav-icon { width: 44rpx; height: 44rpx; padding: 20rpx; }

.play-btn {
  width: 110rpx;
  height: 110rpx;
  background: #a64036;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  margin: 0 40rpx;
  box-shadow: 0 6rpx 20rpx rgba(166, 64, 54, 0.3);
}

.play-btn image { width: 40rpx; height: 40rpx; }

.ctrl-icon-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 80rpx;
}

.icon-border {
  width: 44rpx;
  height: 44rpx;
  border: 2rpx solid #8d7a66;
  border-radius: 50%;
  font-size: 22rpx;
  color: #8d7a66;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-bottom: 8rpx;
}

.active-icon {
  background: #8d7a66;
  color: #fff;
}

.icon-label { font-size: 20rpx; color: #999; }