.container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

.header {
  padding: 40rpx;
  text-align: center;
  background: white;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.content {
  padding: 20rpx;
}

.favorites-list {
  background: white;
  border-radius: 20rpx;
  padding: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.favorite-item {
  padding: 25rpx;
  margin-bottom: 20rpx;
  background: #f8f9fa;
  border-radius: 16rpx;
}

.content {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 10rpx;
  line-height: 1.5;
}

.book-info {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 15rpx;
}

.actions {
  display: flex;
  justify-content: flex-end;
  gap: 15rpx;
}

.btn {
  padding: 10rpx 25rpx;
  background: #667eea;
  border-radius: 20rpx;
  font-size: 26rpx;
  color: white;
}

.btn.remove {
  background: #f44336;
}

.empty-tip {
  text-align: center;
  padding: 60rpx 20rpx;
  color: #999;
  font-size: 28rpx;
}

.section {
  margin-top: 30rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding: 0 10rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.view-all {
  font-size: 28rpx;
  color: #667eea;
}

.popular-list {
  background: white;
  border-radius: 20rpx;
  padding: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.popular-item {
  padding: 20rpx;
  border-bottom: 1rpx solid #eee;
}

.popular-item:last-child {
  border-bottom: none;
}

.content {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 10rpx;
  line-height: 1.5;
}

.book-info {
  font-size: 24rpx;
  color: #999;
}
