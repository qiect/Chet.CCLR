page {
  background-color: #f4f1ea; /* 宣纸色底 */
  height: 100%;
}

.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
}

/* 顶部标题优化 */
.page-header {
  padding: 60rpx 40rpx 40rpx;
  background: #fff;
  text-align: center;
  border-bottom: 1rpx solid #e0dcd3;
}

.title-main {
  font-size: 38rpx;
  font-weight: bold;
  color: #5c4e44;
  letter-spacing: 4rpx;
}

.title-sub {
  font-size: 22rpx;
  color: #a64036;
  margin-top: 10rpx;
  letter-spacing: 2rpx;
}

.scroll-content {
  flex: 1;
  overflow: hidden;
}

/* 收藏卡片设计：书笺感 */
.section-favorites {
  padding: 30rpx;
}

.fav-card {
  display: flex;
  background: #fff;
  border-radius: 12rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(92, 78, 68, 0.08);
  overflow: hidden;
  position: relative;
}

.card-decorator {
  width: 8rpx;
  background: #a64036; /* 朱砂红装饰线 */
}

.card-body {
  flex: 1;
  padding: 30rpx;
}

.sentence-content {
  font-size: 32rpx;
  color: #333;
  line-height: 1.6;
  margin-bottom: 20rpx;
  font-family: serif;
}

.source-info {
  font-size: 24rpx;
  color: #8d7a66;
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
}

.book-tag {
  margin-right: 10rpx;
  font-size: 20rpx;
}

/* 按钮组优化 */
.card-actions {
  display: flex;
  justify-content: flex-end;
  gap: 20rpx;
  border-top: 1rpx solid #f0eee9;
  padding-top: 20rpx;
}

.action-btn {
  display: flex;
  align-items: center;
  padding: 10rpx 24rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  transition: all 0.2s;
}

.play-btn {
  background: #5c4e44;
  color: #fff;
}

.remove-btn {
  background: #fdfaf5;
  color: #999;
  border: 1rpx solid #e0dcd3;
}

.btn-icon {
  width: 24rpx;
  height: 24rpx;
  margin-right: 8rpx;
}

/* 空状态外层容器：确保在列表为空时铺满可用空间 */
.empty-state {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 100rpx 0;
  width: 100%;
}

.empty-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  animation: fadeIn 0.8s ease-out; /* 入场动画 */
}

/* 图片样式：控制尺寸，避免过大产生压迫感 */
.empty-img {
  width: 240rpx;
  height: 240rpx;
  margin-bottom: 30rpx;
  filter: grayscale(0.3); /* 稍微降低饱和度以匹配背景 */
  opacity: 0.7;
}

/* 文字容器 */
.empty-text-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

/* “虚位以待”主文字 */
.empty-title {
  font-size: 30rpx;
  color: #5c4e44;
  font-weight: 500;
  letter-spacing: 4rpx;
  margin-bottom: 12rpx;
}

/* 描述文字 */
.empty-desc {
  font-size: 24rpx;
  color: #8d7a66;
  letter-spacing: 2rpx;
  line-height: 1.5;
  padding: 0 40rpx;
}

/* 简单的呼吸感动画 */
@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* 热门部分优化 */
.section-popular {
  margin-top: 20rpx;
  padding: 0 30rpx 60rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.section-title-box {
  display: flex;
  align-items: center;
}

.title-dot {
  width: 8rpx;
  height: 30rpx;
  background: #a64036;
  margin-right: 15rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #5c4e44;
}

.toggle-link {
  font-size: 24rpx;
  color: #8d7a66;
}

.popular-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 20rpx;
}

.popular-pill {
  background: rgba(255, 255, 255, 0.6);
  padding: 24rpx 30rpx;
  border-radius: 8rpx;
  border: 1rpx solid #e0dcd3;
}

.pop-content {
  font-size: 28rpx;
  color: #444;
  margin-bottom: 8rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.pop-meta {
  font-size: 22rpx;
  color: #999;
}