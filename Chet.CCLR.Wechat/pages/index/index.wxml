<view class="container">
  <view class="header">
    <text class="title">国学经典听读</text>
    <text class="subtitle">沉浸式听读体验</text>
  </view>

  <scroll-view class="scroll-content" scroll-y>
    <!-- 随机句子 -->
    <view class="section">
      <view class="section-header">
        <text class="section-title">每日一句</text>
      </view>
      <view class="sentence-list">
        <view wx:if="{{sentence}}" class="sentence-item">
          <view class="content">{{sentence.content}}</view>
          <view class="translation">{{sentence.translation}}</view>
        </view>
        <view wx:if="{{!sentence}}" class="empty-tip">
          <text>暂无句子数据</text>
        </view>
      </view>
    </view>

    <!-- 最近在听 -->
    <view class="section">
      <view class="section-header">
        <text class="section-title">最近在听</text>
        <text class="view-all" bindtap="viewAllRecent">查看全部 ></text>
      </view>
      <view class="recent-list">
        <block wx:for="{{recentBooks}}" wx:key="id">
          <view class="recent-item" bindtap="onRecentTap" data-book="{{item}}">
            <image class="cover" src="{{item.cover || '/assets/images/book-default.png'}}" mode="aspectFill"></image>
            <view class="info">
              <text class="title">{{item.title}}</text>
              <text class="progress">进度: {{item.progress}}%</text>
            </view>
          </view>
        </block>
        <view wx:if="{{recentBooks.length === 0}}" class="empty-tip">
          <text>暂无听读记录</text>
        </view>
      </view>
    </view>

    <!-- 书目列表 -->
    <view class="section">
      <view class="section-header">
        <text class="section-title">全部书目</text>
        <text class="view-all" bindtap="viewAllBooks">查看全部 ></text>
      </view>
      <view class="book-list">
        <block wx:for="{{books}}" wx:key="id">
          <view class="book-item" bindtap="onBookTap" data-book="{{item}}">
            <image class="cover" src="{{item.cover || '/assets/images/book-default.png'}}" mode="aspectFill"></image>
            <view class="info">
              <text class="title">{{item.title}}</text>
              <text class="category">{{item.category}}</text>
            </view>
          </view>
        </block>
      </view>
    </view>
  </scroll-view>
</view>
