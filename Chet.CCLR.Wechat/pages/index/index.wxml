<view class="container">
  <view class="header">
    <view class="header-content">
      <text class="title">国学经典听读</text>
      <text class="subtitle">书山有路勤为径，学海无涯苦作舟</text>
    </view>
    <view class="header-decoration"></view>
  </view>

  <scroll-view class="scroll-content" scroll-y enable-passive>
    <view class="section">
      <view class="section-header">
        <text class="section-title">每日一句</text>
      </view>
      <view class="quote-card">
        <view class="quote-mark">“</view>
        <view wx:if="{{sentence}}" class="sentence-body">
          <view class="content">{{sentence.content}}</view>
          <view class="translation">{{sentence.translation}}</view>
        </view>
        <view wx:else class="empty-tip">焚香静候，佳句自来</view>
      </view>
    </view>

    <view class="section">
      <view class="section-header">
        <text class="section-title">最近在听</text>
        <text class="view-all" bindtap="viewAllRecent">查看全部</text>
      </view>
      <scroll-view class="recent-scroll" scroll-x>
        <view class="recent-list">
          <block wx:for="{{recentBooks}}" wx:key="id">
            <view class="recent-item" bindtap="onRecentTap" data-book="{{item}}">
              <image class="cover" src="{{item.cover || '/assets/images/book-default.png'}}" mode="aspectFill"></image>
              <view class="info">
                <text class="book-name">{{item.title}}</text>
                <view class="progress-bar">
                  <view class="progress-inner" style="width: {{item.progress}}%"></view>
                </view>
                <text class="progress-text">已学 {{item.progress}}%</text>
              </view>
            </view>
          </block>
          <view wx:if="{{recentBooks.length === 0}}" class="empty-tip-small">暂无记录</view>
        </view>
      </scroll-view>
    </view>

    <view class="section">
      <view class="section-header">
        <text class="section-title">推荐书目</text>
        <text class="view-all" bindtap="viewAllBooks">查看全部</text>
      </view>
      <view class="book-grid">
        <block wx:for="{{recommendedBooks}}" wx:key="id">
          <view class="book-card" bindtap="onBookTap" data-book="{{item}}">
            <image class="book-cover" src="{{item.cover || '/assets/images/book-default.png'}}" mode="aspectFill"></image>
            <view class="book-info">
              <text class="book-title">{{item.title}}</text>
              <text class="book-tag">{{item.category}}</text>
            </view>
          </view>
        </block>
      </view>
    </view>
  </scroll-view>
</view>