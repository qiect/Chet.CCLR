/* 全局背景色：宣纸白 */
.container {
  min-height: 100vh;
  background-color: #f9f7f2;
  color: #333;
}

/* Header 样式：黛蓝底色 */
.header {
  padding: 80rpx 40rpx 60rpx;
  background-color: #2c3e50; /* 黛蓝 */
  color: #e0d1b1; /* 浅米色字 */
  position: relative;
  overflow: hidden;
}

.title {
  font-size: 46rpx;
  font-weight: 600;
  letter-spacing: 4rpx;
  display: block;
  margin-bottom: 16rpx;
}

.subtitle {
  font-size: 24rpx;
  opacity: 0.7;
  font-style: italic;
}

/* 装饰性元素 */
.header-decoration {
  position: absolute;
  right: -40rpx;
  top: -40rpx;
  width: 200rpx;
  height: 200rpx;
  border: 2rpx solid rgba(224, 209, 177, 0.1);
  border-radius: 50%;
}

/* 模块通用标题 */
.section {
  padding: 30rpx 20rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  padding: 0 10rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #1a1a1a;
  position: relative;
  padding-left: 24rpx;
}

.section-title::before {
  content: "";
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 30rpx;
  background-color: #a64036; /* 朱砂红 */
}

.view-all {
  font-size: 26rpx;
  color: #888;
}

/* 每日一句卡片 */
.quote-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 50rpx 40rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.05);
  position: relative;
  border: 1rpx solid #eee;
}

.quote-mark {
  position: absolute;
  top: 10rpx;
  left: 30rpx;
  font-size: 80rpx;
  color: #f0f0f0;
  font-family: serif;
}

.content {
  font-size: 36rpx;
  line-height: 1.6;
  color: #333;
  margin-bottom: 20rpx;
  position: relative;
  z-index: 1;
}

.translation {
  font-size: 26rpx;
  color: #777;
  border-top: 1rpx dashed #eee;
  padding-top: 20rpx;
}

/* 最近在听：横向滑动 */
.recent-scroll {
  width: 100%;
  white-space: nowrap;
}

.recent-list {
  display: flex;
  padding: 10rpx;
}

.recent-item {
  width: 280rpx;
  margin-right: 24rpx;
  background: #fff;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.06);
  flex-shrink: 0;
}

.recent-item .cover {
  width: 100%;
  height: 200rpx;
}

.recent-item .info {
  padding: 16rpx;
}

.book-name {
  font-size: 28rpx;
  font-weight: 500;
  display: block;
  margin-bottom: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
}

.progress-bar {
  height: 6rpx;
  background: #eee;
  border-radius: 3rpx;
  margin-bottom: 8rpx;
}

.progress-inner {
  height: 100%;
  background: #a64036;
  border-radius: 3rpx;
}

.progress-text {
  font-size: 20rpx;
  color: #999;
}

/* 推荐书目网格 */
.book-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  padding: 0 10rpx;
}

.book-card {
  width: 47%;
  margin-bottom: 30rpx;
}

.book-cover {
  width: 100%;
  height: 380rpx;
  border-radius: 8rpx;
  box-shadow: 4rpx 6rpx 16rpx rgba(0,0,0,0.15); /* 给书封加深点阴影，更有厚重感 */
}

.book-info {
  margin-top: 16rpx;
}

.book-title {
  font-size: 28rpx;
  font-weight: 500;
  display: block;
}

.book-tag {
  font-size: 22rpx;
  color: #a64036;
  border: 1rpx solid #a64036;
  padding: 2rpx 8rpx;
  border-radius: 4rpx;
  margin-top: 8rpx;
  display: inline-block;
}