<view class="container">
  <view class="header">
    <view class="book-info">
      <text class="book-title">{{bookTitle}}</text>
      <text wx:if="{{chapter}}" class="chapter-title">{{chapter.title}}</text>
    </view>
  </view>

  <scroll-view class="content" scroll-y scroll-into-view="{{scrollY}}">
    <view class="sentences">
      <block wx:for="{{sentences}}" wx:key="id">
        <view id="sentence-{{index}}" class="sentence-item {{currentIndex === index ? 'active' : ''}}" bindtap="onSentenceTap" data-index="{{index}}">
          <view class="pinyin" wx:if="{{showPinyin && item.pinyin}}">{{item.pinyin}}</view>
          <view class="content">{{item.content}}</view>
          <view class="note" wx:if="{{showNote && currentIndex === index}}">{{currentSentenceNote}}</view>
        </view>
      </block>
    </view>
  </scroll-view>

  <view class="controls">
    <view class="progress-bar">
      <view class="progress-bg">
        <view class="progress-fill" style="width: {{duration > 0 ? (currentTime / duration * 100) : 0}}%"></view>
      </view>
      <view class="time-display">
        <text>{{formatDuration(currentTime)}}</text>
        <text>/</text>
        <text>{{formatDuration(duration)}}</text>
      </view>
    </view>

    <view class="control-buttons">
      <view class="btn prev" bindtap="playPrev">
        <image src="/assets/icons/prev.png" mode="aspectFit"></image>
      </view>
      <view class="btn play" bindtap="togglePlay">
        <image wx:if="{{!isPlaying}}" src="/assets/icons/play.png" mode="aspectFit"></image>
        <image wx:if="{{isPlaying}}" src="/assets/icons/pause.png" mode="aspectFit"></image>
      </view>
      <view class="btn next" bindtap="playNext">
        <image src="/assets/icons/next.png" mode="aspectFit"></image>
      </view>
    </view>

    <view class="action-buttons">
      <view class="btn toggle-pinyin" bindtap="togglePinyin">
        <text wx:if="{{showPinyin}}">隐藏拼音</text>
        <text wx:if="{{!showPinyin}}">显示拼音</text>
      </view>
    </view>
  </view>
</view>
