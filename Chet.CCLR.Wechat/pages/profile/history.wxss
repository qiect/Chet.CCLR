.container {
  padding: 20rpx;
}

.history-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.history-item {
  padding: 30rpx;
  background: #fff;
  border-radius: 12rpx;
}

.book-info {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  margin-bottom: 20rpx;
}

.book-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.progress-info {
  font-size: 28rpx;
  color: #666;
}

.progress-bar {
  width: 100%;
  height: 16rpx;
  background: #f0f0f0;
  border-radius: 8rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #ff6b6b, #ff8e53);
  border-radius: 8rpx;
}

.last-time {
  font-size: 26rpx;
  color: #999;
}

.empty-tip {
  text-align: center;
  padding: 100rpx;
  color: #999;
}
