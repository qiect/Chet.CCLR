<view class="container">
  <view class="user-header">
    <view class="user-info">
      <view class="avatar-wrapper">
        <image class="avatar" src="{{userInfo && userInfo.avatar ? userInfo.avatar : '/assets/icons/user-default.png'}}" mode="aspectFill"></image>
        <view class="avatar-seal"></view>
      </view>
      <view class="user-text">
        <text class="username">{{userInfo && userInfo.nickname ? userInfo.nickname : '访客'}}</text>
        <text class="user-motto">读书百遍，其义自见</text>
      </view>
    </view>
  </view>

  <scroll-view class="content-scroll" scroll-y>
    <view class="stats-scroll-box">
      <view class="stat-item">
        <text class="stat-label">连续研习</text>
        <view class="stat-value-group">
          <text class="stat-value">{{stats.consecutiveDays}}</text>
          <text class="stat-unit">天</text>
        </view>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-label">累计听读</text>
        <view class="stat-value-group">
          <text class="stat-value">{{formatDuration(stats.totalDuration)}}</text>
        </view>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-label">今日进学</text>
        <view class="stat-value-group">
          <text class="stat-value">{{formatDuration(stats.todayDuration)}}</text>
        </view>
      </view>
    </view>

    <view class="menu-group">
      <view class="menu-cell" bindtap="viewHistory">
        <view class="cell-left">
          <view class="cell-icon history-icon"></view>
          <view class="cell-text">
            <text class="cell-title">听读历史</text>
            <text class="cell-desc">溯源过往闻学足迹</text>
          </view>
        </view>
        <text class="cell-arrow">></text>
      </view>

      <view class="menu-cell" bindtap="viewFavorites">
        <view class="cell-left">
          <view class="cell-icon heart-icon"></view>
          <view class="cell-text">
            <text class="cell-title">我的收藏</text>
            <text class="cell-desc">{{favoritesCount}} 句金石良言</text>
          </view>
        </view>
        <text class="cell-arrow">></text>
      </view>

      <view class="menu-cell" bindtap="viewSettings">
        <view class="cell-left">
          <view class="cell-icon settings-icon"></view>
          <view class="cell-text">
            <text class="cell-title">设置</text>
            <text class="cell-desc">调整听读偏好设置</text>
          </view>
        </view>
        <text class="cell-arrow">></text>
      </view>
    </view>

    <view class="section-popular">
      <view class="section-head">
        <view class="section-title-box">
          <view class="title-line"></view>
          <text class="section-title">热门雅句</text>
        </view>
        <text class="view-all-link" bindtap="viewPopular">查看全部</text>
      </view>
      
      <view class="popular-card-list">
        <block wx:for="{{popularFavorites}}" wx:key="id">
          <view class="popular-card" bindtap="onSentenceTap" data-sentence="{{item}}">
            <text class="popular-content">“{{item.content}}”</text>
            <view class="popular-source">
              <text>—— {{item.bookTitle}} · {{item.chapterTitle}}</text>
            </view>
          </view>
        </block>
      </view>
    </view>
    
    <view class="safe-area-inset"></view>
  </scroll-view>
</view>