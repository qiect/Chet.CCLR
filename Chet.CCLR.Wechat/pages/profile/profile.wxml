<view class="container">
  <view class="header">
    <view class="user-info">
      <view class="avatar">
        <image src="/assets/icons/user-default.png" mode="aspectFill"></image>
      </view>
      <view class="name">
        <text class="username">用户</text>
      </view>
    </view>
  </view>

  <scroll-view class="content" scroll-y>
    <!-- 统计卡片 -->
    <view class="stats-card">
      <view class="stat-item">
        <text class="stat-value">{{stats.consecutiveDays}}</text>
        <text class="stat-label">连续天数</text>
      </view>
      <view class="stat-item">
        <text class="stat-value">{{formatDuration(stats.totalDuration)}}</text>
        <text class="stat-label">累计时长</text>
      </view>
      <view class="stat-item">
        <text class="stat-value">{{formatDuration(stats.todayDuration)}}</text>
        <text class="stat-label">今日时长</text>
      </view>
    </view>

    <!-- 功能列表 -->
    <view class="menu-list">
      <view class="menu-item" bindtap="viewHistory">
        <view class="icon">
          <image src="/assets/icons/history.png" mode="aspectFit"></image>
        </view>
        <view class="text">
          <text class="title">听读历史</text>
          <text class="desc">查看最近听读记录</text>
        </view>
        <view class="arrow">
          <image src="/assets/icons/arrow-right.png" mode="aspectFit"></image>
        </view>
      </view>

      <view class="menu-item" bindtap="viewFavorites">
        <view class="icon">
          <image src="/assets/icons/heart.png" mode="aspectFit"></image>
        </view>
        <view class="text">
          <text class="title">我的收藏</text>
          <text class="desc">{{favoritesCount}}句收藏</text>
        </view>
        <view class="arrow">
          <image src="/assets/icons/arrow-right.png" mode="aspectFit"></image>
        </view>
      </view>

      <view class="menu-item" bindtap="viewSettings">
        <view class="icon">
          <image src="/assets/icons/settings.png" mode="aspectFit"></image>
        </view>
        <view class="text">
          <text class="title">设置</text>
          <text class="desc">听读偏好设置</text>
        </view>
        <view class="arrow">
          <image src="/assets/icons/arrow-right.png" mode="aspectFit"></image>
        </view>
      </view>
    </view>

    <!-- 热门收藏 -->
    <view class="section">
      <view class="section-header">
        <text class="section-title">热门收藏</text>
        <text class="view-all" bindtap="viewPopular">查看全部 ></text>
      </view>
      <view class="popular-list">
        <block wx:for="{{popularFavorites}}" wx:key="id">
          <view class="popular-item" bindtap="onSentenceTap" data-sentence="{{item}}">
            <text class="content">{{item.content}}</text>
            <text class="book-info">{{item.bookTitle}} · {{item.chapterTitle}}</text>
          </view>
        </block>
      </view>
    </view>
  </scroll-view>
</view>
