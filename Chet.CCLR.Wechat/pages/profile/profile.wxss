page {
  background-color: #f4f1ea; /* 宣纸底色 */
  height: 100%;
}

.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
}

/* 顶部头像区域优化 */
.user-header {
  padding: 80rpx 50rpx 50rpx;
  background-color: #ffffff;
  border-bottom: 1rpx solid #e0dcd3;
}

.user-info {
  display: flex;
  align-items: center;
}

.avatar-wrapper {
  position: relative;
  width: 140rpx;
  height: 140rpx;
  margin-right: 30rpx;
}

.avatar {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  border: 1rpx solid #e0dcd3;
  padding: 6rpx;
  background: #fff;
}

.avatar-seal {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 24rpx;
  height: 24rpx;
  background-color: #a64036; /* 朱砂红印章感 */
  border: 4rpx solid #fff;
  border-radius: 4rpx;
}

.user-text {
  display: flex;
  flex-direction: column;
}

.username {
  font-size: 40rpx;
  font-weight: bold;
  color: #5c4e44;
  letter-spacing: 2rpx;
}

.user-motto {
  font-size: 24rpx;
  color: #8d7a66;
  margin-top: 10rpx;
  font-style: italic;
}

/* 统计卡片：横向卷轴感 */
.stats-scroll-box {
  background: #fff;
  margin: 30rpx;
  padding: 40rpx 0;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 20rpx rgba(92, 78, 68, 0.08);
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-divider {
  width: 1rpx;
  height: 60rpx;
  background-color: #f0eee9;
}

.stat-label {
  font-size: 22rpx;
  color: #8d7a66;
  display: block;
  margin-bottom: 12rpx;
}

.stat-value {
  font-size: 38rpx;
  font-weight: bold;
  color: #a64036; /* 朱砂红强调数据 */
  font-family: serif;
}

.stat-unit {
  font-size: 20rpx;
  color: #8d7a66;
  margin-left: 4rpx;
}

/* 菜单组：木质简约 */
.menu-group {
  background: #fff;
  margin: 0 30rpx 40rpx;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(92, 78, 68, 0.05);
}

.menu-cell {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 35rpx 30rpx;
  border-bottom: 1rpx solid #f8f6f2;
}

.menu-cell:last-child {
  border-bottom: none;
}

.cell-left {
  display: flex;
  align-items: center;
}

.cell-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 25rpx;
  background-color: #f4f1ea;
  border-radius: 8rpx;
}

/* 占位图标颜色 */
.history-icon { background: #e8e4db; }
.heart-icon { background: #f2e2e1; }
.settings-icon { background: #e0e4e8; }

.cell-title {
  display: block;
  font-size: 30rpx;
  color: #5c4e44;
  font-weight: 500;
}

.cell-desc {
  font-size: 22rpx;
  color: #bbb3a9;
}

.cell-arrow {
  color: #d1cbc3;
  font-size: 24rpx;
}

/* 热门金句：信笺风格 */
.section-popular {
  padding: 0 30rpx 60rpx;
}

.section-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 25rpx;
}

.section-title-box {
  display: flex;
  align-items: center;
}

.title-line {
  width: 6rpx;
  height: 28rpx;
  background: #a64036;
  margin-right: 15rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #5c4e44;
}

.view-all-link {
  font-size: 24rpx;
  color: #8d7a66;
}

.popular-card {
  background: #fff;
  padding: 30rpx;
  border-radius: 8rpx;
  margin-bottom: 20rpx;
  border-left: 6rpx solid #e0dcd3;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.02);
}

.popular-content {
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  font-family: serif;
  display: block;
}

.popular-source {
  text-align: right;
  font-size: 22rpx;
  color: #999;
  margin-top: 15rpx;
}

.safe-area-inset {
  height: 60rpx;
}