page {
  background-color: #f4f1ea;
  height: 100%;
}

.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
}

/* 顶部 Header */
.page-header {
  background-color: #ffffff;
  padding: 60rpx 40rpx 40rpx;
  border-bottom: 1rpx solid #e0dcd3;
  flex-shrink: 0;
}

.header-main {
  text-align: center;
}

.page-title {
  font-size: 38rpx;
  font-weight: bold;
  color: #5c4e44;
  letter-spacing: 6rpx;
  display: block;
}

.page-subtitle {
  font-size: 22rpx;
  color: #a64036;
  margin-top: 12rpx;
  display: block;
  opacity: 0.8;
}

/* 滚动区域 */
.scroll-content {
  flex: 1;
  overflow: hidden;
}

.book-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 30rpx 25rpx;
  justify-content: space-between;
}

/* 书籍卡片 */
.book-card {
  width: 334rpx;
  background: #ffffff;
  margin-bottom: 40rpx;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 24rpx rgba(92, 78, 68, 0.12);
}

/* 封面与进度标签 */
.cover-wrapper {
  position: relative;
  width: 100%;
  height: 420rpx;
}

.book-cover {
  width: 100%;
  height: 100%;
}

.book-spine {
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 14rpx;
  background: linear-gradient(to right, rgba(0,0,0,0.25), rgba(0,0,0,0));
}

.progress-badge {
  position: absolute;
  right: 12rpx;
  top: 12rpx;
  background: rgba(166, 64, 54, 0.85);
  color: #fff;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  backdrop-filter: blur(4px);
}

/* 信息区 */
.book-info {
  padding: 24rpx 20rpx;
}

.book-title {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-bottom: 16rpx;
  font-family: serif;
}

/* 进度条可视化优化 */
.progress-bar-container {
  width: 100%;
  height: 6rpx;
  background: #eeebe3;
  border-radius: 3rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: #a64036; /* 朱砂红进度 */
  border-radius: 3rpx;
  transition: width 0.6s ease;
}

/* 空状态 (复用之前的样式) */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
}

.empty-img {
  width: 240rpx;
  height: 240rpx;
  opacity: 0.7;
}

.empty-text-box {
  margin-top: 40rpx;
  text-align: center;
}

.empty-title {
  font-size: 32rpx;
  color: #5c4e44;
  display: block;
}

.empty-desc {
  font-size: 24rpx;
  color: #8d7a66;
  margin-top: 10rpx;
  display: block;
}

.footer-gap { height: 80rpx; }